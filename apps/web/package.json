{
  "name": "@better-life/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 5173 --host",
    "build": "vite build",
    "preview": "node build",
    "prepare": "(npx @inlang/paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide || echo 'paraglide compile skipped') && (svelte-kit sync || echo '')",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@better-life/contracts": "*",
    "@better-life/emails": "*",
    "dotenv": "^16.4.7",
    "inngest": "^4.5.0",
    "pg": "^8.13.1",
    "resend": "^4.6.0"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.0.0",
    "@sveltejs/adapter-node": "^5.2.12",
    "@sveltejs/kit": "^2.15.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "svelte": "^5.19.0",
    "svelte-check": "^4.1.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
