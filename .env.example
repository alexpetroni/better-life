# ─────────────────────────────────────────────────────────────────────────────
# Better Life — Phase 1 environment
# Copy to `.env` (`cp .env.example .env`). Every integration degrades gracefully
# when its credentials are absent: a missing key logs a warning and disables only
# that capability — it never crashes the app or blocks local/dev work.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# One Postgres, three isolated schemas: app, payload, (medusa reserved for Phase 2).
# Local dev points at the docker-compose Postgres; prod points at Supabase.
#
# DIRECT_URL — session/direct connection (port 5432). Used by migrations and Payload.
#              (Never the transaction pooler: it breaks prepared statements + advisory locks.)
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/better_life
# DATABASE_URL — app-runtime queries from the SvelteKit BFF. In prod this is the
#              Supabase transaction pooler (port 6543). Locally there is no pooler,
#              so it mirrors DIRECT_URL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/better_life

# ── Redis ───────────────────────────────────────────────────────────────────--
# Present for stack parity. No Phase 1 consumer — Medusa + the Inngest worker use it from Phase 2.
REDIS_URL=redis://localhost:6379

# ── Payload CMS ─────────────────────────────────────────────────────────────--
PAYLOAD_SECRET=dev-secret-change-me-in-production
# Where the CMS (admin + REST/GraphQL API) is served. The SvelteKit BFF is its only caller.
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001
PORT_CMS=3001

# ── SvelteKit web ───────────────────────────────────────────────────────────--
# Public canonical site URL (used for sitemap, canonical tags, OG/Twitter, JSON-LD).
PUBLIC_SITE_URL=http://localhost:5173
# Default brand resolution until the Phase 2 reverse proxy decides host→route-group.
# One of: betterlife | somnium
PUBLIC_DEFAULT_BRAND=betterlife

# ── Email (Resend) ──────────────────────────────────────────────────────────--
# Absent key → email sending is disabled with a startup warning; the rest of the flow still works.
RESEND_API_KEY=
EMAIL_FROM=Better Life <hello@betterlife.ro>

# ── i18n ────────────────────────────────────────────────────────────────────--
# Romanian first. English is added later with no retrofit.
PUBLIC_DEFAULT_LOCALE=ro
